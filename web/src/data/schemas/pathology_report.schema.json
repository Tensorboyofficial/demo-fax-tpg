{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cevi.ai/schemas/pathology_report.schema.json",
  "title": "Cevi AI \u2014 Pathology Report",
  "description": "Anatomic and clinical pathology report (biopsies, cytology). Each specimen (part A/B/C) captured separately with gross description, microscopic description, diagnosis, and margins as printed. CAP synoptic summaries and ancillary IHC/FISH/molecular studies captured as narrative strings.",
  "type": "object",
  "properties": {
    "document_category": {
      "type": "string",
      "const": "pathology_report"
    },
    "document_subcategory": {
      "type": "string",
      "enum": [
        "surgical_pathology",
        "cytology",
        "fine_needle_aspiration",
        "bone_marrow",
        "autopsy",
        "other"
      ]
    },
    "patient": {
      "type": "object",
      "description": "Patient as identified on the fax. Does NOT include eCW account number or matcher output \u2014 matching runs after extraction.",
      "properties": {
        "name": {
          "type": "object",
          "description": "Person name with verbatim raw_text plus parsed components for separate copy-paste.",
          "properties": {
            "raw_text": {
              "type": "string",
              "description": "Verbatim name string as printed."
            },
            "first_name": {
              "type": "string"
            },
            "middle_name": {
              "type": "string"
            },
            "last_name": {
              "type": "string"
            },
            "suffix": {
              "type": "string"
            }
          }
        },
        "dob": {
          "type": "string",
          "format": "date",
          "description": "ISO date YYYY-MM-DD when parseable. Omit if ambiguous."
        },
        "dob_raw": {
          "type": "string",
          "description": "Verbatim DOB string as printed."
        },
        "sex": {
          "type": "string",
          "description": "Sex as printed. Typical values: M, F, Male, Female, Unknown."
        },
        "address": {
          "type": "object",
          "description": "Postal address from document. Each component is its own field.",
          "properties": {
            "raw_text": {
              "type": "string",
              "description": "Verbatim multi-line address as printed."
            },
            "line1": {
              "type": "string"
            },
            "line2": {
              "type": "string",
              "description": "Apt, Suite, Unit, etc."
            },
            "city": {
              "type": "string"
            },
            "state": {
              "type": "string",
              "description": "2-letter state code."
            },
            "postal_code": {
              "type": "string"
            }
          }
        },
        "phone": {
          "type": "object",
          "description": "Phone/fax as shown on document.",
          "properties": {
            "raw_text": {
              "type": "string"
            },
            "digits": {
              "type": "string",
              "description": "10-digit US number, digits only."
            },
            "extension": {
              "type": "string"
            }
          }
        },
        "identifiers": {
          "type": "array",
          "description": "Patient identifiers printed on the fax. Captured as printed with the label used.",
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string",
                "description": "Label as printed: 'Lab MRN', 'Account #', 'Member ID', etc."
              },
              "value": {
                "type": "string"
              }
            },
            "required": [
              "label",
              "value"
            ]
          }
        }
      }
    },
    "sender": {
      "type": "object",
      "description": "Organization that sent the fax (lab, hospital, pharmacy, law firm, payer, etc.).",
      "properties": {
        "name": {
          "type": "string"
        },
        "address": {
          "type": "object",
          "description": "Postal address from document. Each component is its own field.",
          "properties": {
            "raw_text": {
              "type": "string",
              "description": "Verbatim multi-line address as printed."
            },
            "line1": {
              "type": "string"
            },
            "line2": {
              "type": "string",
              "description": "Apt, Suite, Unit, etc."
            },
            "city": {
              "type": "string"
            },
            "state": {
              "type": "string",
              "description": "2-letter state code."
            },
            "postal_code": {
              "type": "string"
            }
          }
        },
        "phone": {
          "type": "object",
          "description": "Phone/fax as shown on document.",
          "properties": {
            "raw_text": {
              "type": "string"
            },
            "digits": {
              "type": "string",
              "description": "10-digit US number, digits only."
            },
            "extension": {
              "type": "string"
            }
          }
        },
        "fax": {
          "type": "object",
          "description": "Phone/fax as shown on document.",
          "properties": {
            "raw_text": {
              "type": "string"
            },
            "digits": {
              "type": "string",
              "description": "10-digit US number, digits only."
            },
            "extension": {
              "type": "string"
            }
          }
        },
        "clia_number": {
          "type": "string",
          "description": "CLIA only if printed."
        },
        "lab_director": {
          "type": "string",
          "description": "Laboratory director name, if printed."
        }
      }
    },
    "providers": {
      "type": "array",
      "description": "All providers named on the document with their role.",
      "items": {
        "type": "object",
        "description": "Provider as identified on the fax. Only from text on the page.",
        "properties": {
          "role": {
            "type": "string",
            "description": "Role as printed or implied by section: 'Ordering', 'Attending', 'Radiologist', 'Signed by', etc."
          },
          "name": {
            "type": "object",
            "properties": {
              "raw_text": {
                "type": "string"
              },
              "prefix": {
                "type": "string",
                "description": "Dr., etc."
              },
              "first_name": {
                "type": "string"
              },
              "middle_name": {
                "type": "string"
              },
              "last_name": {
                "type": "string"
              },
              "suffix": {
                "type": "string"
              }
            }
          },
          "credentials": {
            "type": "array",
            "description": "Credentials as printed: ['MD'], ['DO','FACP'], ['NP'].",
            "items": {
              "type": "string"
            }
          },
          "npi": {
            "type": "string",
            "description": "NPI only if printed on the fax."
          },
          "specialty": {
            "type": "string"
          },
          "phone": {
            "type": "object",
            "description": "Phone/fax as shown on document.",
            "properties": {
              "raw_text": {
                "type": "string"
              },
              "digits": {
                "type": "string",
                "description": "10-digit US number, digits only."
              },
              "extension": {
                "type": "string"
              }
            }
          },
          "fax": {
            "type": "object",
            "description": "Phone/fax as shown on document.",
            "properties": {
              "raw_text": {
                "type": "string"
              },
              "digits": {
                "type": "string",
                "description": "10-digit US number, digits only."
              },
              "extension": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "accession_number": {
      "type": "string"
    },
    "report_status": {
      "type": "string"
    },
    "specimens": {
      "type": "array",
      "description": "Each specimen submitted (part A/B/C in pathology convention).",
      "items": {
        "type": "object",
        "properties": {
          "part_label": {
            "type": "string",
            "description": "Part designator as printed: 'A', 'B', '1', '2'."
          },
          "description": {
            "type": "string",
            "description": "Specimen description as printed."
          },
          "anatomic_site": {
            "type": "string"
          },
          "procedure": {
            "type": "string",
            "description": "How specimen was obtained: 'shave biopsy', 'excisional biopsy', 'core needle'."
          },
          "collected_at": {
            "type": "string",
            "format": "date-time"
          },
          "collected_at_raw": {
            "type": "string"
          },
          "gross_description": {
            "type": "string"
          },
          "microscopic_description": {
            "type": "string"
          },
          "diagnosis": {
            "type": "string",
            "description": "Diagnosis for this specimen as printed."
          },
          "margins": {
            "type": "string"
          }
        }
      }
    },
    "final_diagnosis": {
      "type": "string",
      "description": "Consolidated final diagnosis section verbatim."
    },
    "clinical_history": {
      "type": "string"
    },
    "comment": {
      "type": "string"
    },
    "synoptic_summary": {
      "type": "string",
      "description": "CAP synoptic summary text verbatim, if present."
    },
    "ancillary_studies": {
      "type": "string",
      "description": "IHC, FISH, molecular studies as printed."
    },
    "received_at": {
      "type": "string",
      "format": "date-time"
    },
    "signed_at": {
      "type": "string",
      "format": "date-time"
    },
    "full_text": {
      "type": "string",
      "description": "Full OCR text of the document for auditing, search, and reprocessing."
    },
    "fax_envelope": {
      "type": "object",
      "description": "Transmission metadata from fax service \u2014 not content from the document.",
      "properties": {
        "received_at": {
          "type": "string",
          "format": "date-time"
        },
        "from_fax_number": {
          "type": "string"
        },
        "to_fax_number": {
          "type": "string"
        },
        "csid_banner": {
          "type": "string"
        },
        "page_count": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "extraction_meta": {
      "type": "object",
      "properties": {
        "extractor_version": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "schema_id": {
          "type": "string"
        },
        "extracted_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  },
  "required": [
    "document_category",
    "patient"
  ],
  "examples": [
    {
      "document_category": "pathology_report",
      "document_subcategory": "surgical_pathology",
      "patient": {
        "name": {
          "raw_text": "WASHINGTON, DESHAWN JAMAL",
          "first_name": "DeShawn",
          "middle_name": "Jamal",
          "last_name": "Washington"
        },
        "dob": "1971-09-03",
        "dob_raw": "09/03/1971",
        "sex": "M",
        "identifiers": [
          {
            "label": "MRN",
            "value": "PPT-102847"
          }
        ]
      },
      "sender": {
        "name": "ProPath Services",
        "address": {
          "raw_text": "Dallas, TX",
          "city": "Dallas",
          "state": "TX"
        },
        "clia_number": "45D0923456"
      },
      "providers": [
        {
          "role": "Ordering",
          "name": {
            "raw_text": "Priya Patel, DO, FACP",
            "first_name": "Priya",
            "last_name": "Patel"
          },
          "credentials": [
            "DO",
            "FACP"
          ]
        },
        {
          "role": "Pathologist",
          "name": {
            "raw_text": "Margaret Sullivan, MD",
            "first_name": "Margaret",
            "last_name": "Sullivan"
          },
          "credentials": [
            "MD"
          ]
        }
      ],
      "accession_number": "S26-04823",
      "report_status": "Final",
      "specimens": [
        {
          "part_label": "A",
          "description": "Skin, left forearm, shave biopsy",
          "anatomic_site": "Left forearm, skin",
          "procedure": "Shave biopsy",
          "collected_at": "2026-04-10T10:15:00",
          "collected_at_raw": "04/10/2026 10:15",
          "gross_description": "The specimen is received in formalin, labeled with the patient's name. Consists of a tan-brown shave of skin measuring 0.6 x 0.4 x 0.2 cm. Entirely submitted in cassette A1.",
          "microscopic_description": "Sections show skin with an atypical melanocytic proliferation. There is nested and single-cell proliferation of atypical melanocytes at the dermoepidermal junction extending into the papillary dermis.",
          "diagnosis": "Compound dysplastic nevus with moderate cytologic atypia. Lesion extends to the lateral and deep margins.",
          "margins": "Positive at lateral and deep margins"
        }
      ],
      "comment": "The presence of moderate cytologic atypia with positive margins warrants re-excision with 2-5 mm clear margins per current consensus guidelines.",
      "signed_at": "2026-04-15T11:20:00",
      "fax_envelope": {
        "received_at": "2026-04-15T12:47:33",
        "page_count": 2
      },
      "extraction_meta": {
        "extractor_version": "0.1.0",
        "schema_id": "https://cevi.ai/schemas/pathology_report.schema.json",
        "extracted_at": "2026-04-15T12:48:19"
      }
    }
  ]
}