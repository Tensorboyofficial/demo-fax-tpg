{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cevi.ai/schemas/unclassified.schema.json",
  "title": "Cevi AI \u2014 Unclassified",
  "description": "Catchall for documents the classifier cannot confidently assign to any of the 24 content categories. Captures top candidate categories with confidence, key excerpts, and why classification failed. Drives human review queue and classifier-improvement feedback loop.",
  "type": "object",
  "properties": {
    "document_category": {
      "type": "string",
      "const": "unclassified"
    },
    "document_subcategory": {
      "type": "string",
      "enum": [
        "ambiguous",
        "low_quality",
        "partial_document",
        "foreign_language",
        "handwritten_only",
        "other"
      ]
    },
    "patient": {
      "type": "object",
      "description": "Patient as identified on the fax. Does NOT include eCW account number or matcher output \u2014 matching runs after extraction.",
      "properties": {
        "name": {
          "type": "object",
          "description": "Person name with verbatim raw_text plus parsed components for separate copy-paste.",
          "properties": {
            "raw_text": {
              "type": "string",
              "description": "Verbatim name string as printed."
            },
            "first_name": {
              "type": "string"
            },
            "middle_name": {
              "type": "string"
            },
            "last_name": {
              "type": "string"
            },
            "suffix": {
              "type": "string"
            }
          }
        },
        "dob": {
          "type": "string",
          "format": "date",
          "description": "ISO date YYYY-MM-DD when parseable. Omit if ambiguous."
        },
        "dob_raw": {
          "type": "string",
          "description": "Verbatim DOB string as printed."
        },
        "sex": {
          "type": "string",
          "description": "Sex as printed. Typical values: M, F, Male, Female, Unknown."
        },
        "address": {
          "type": "object",
          "description": "Postal address from document. Each component is its own field.",
          "properties": {
            "raw_text": {
              "type": "string",
              "description": "Verbatim multi-line address as printed."
            },
            "line1": {
              "type": "string"
            },
            "line2": {
              "type": "string",
              "description": "Apt, Suite, Unit, etc."
            },
            "city": {
              "type": "string"
            },
            "state": {
              "type": "string",
              "description": "2-letter state code."
            },
            "postal_code": {
              "type": "string"
            }
          }
        },
        "phone": {
          "type": "object",
          "description": "Phone/fax as shown on document.",
          "properties": {
            "raw_text": {
              "type": "string"
            },
            "digits": {
              "type": "string",
              "description": "10-digit US number, digits only."
            },
            "extension": {
              "type": "string"
            }
          }
        },
        "identifiers": {
          "type": "array",
          "description": "Patient identifiers printed on the fax. Captured as printed with the label used.",
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string",
                "description": "Label as printed: 'Lab MRN', 'Account #', 'Member ID', etc."
              },
              "value": {
                "type": "string"
              }
            },
            "required": [
              "label",
              "value"
            ]
          }
        }
      }
    },
    "sender": {
      "type": "object",
      "description": "Organization that sent the fax (lab, hospital, pharmacy, law firm, payer, etc.).",
      "properties": {
        "name": {
          "type": "string"
        },
        "address": {
          "type": "object",
          "description": "Postal address from document. Each component is its own field.",
          "properties": {
            "raw_text": {
              "type": "string",
              "description": "Verbatim multi-line address as printed."
            },
            "line1": {
              "type": "string"
            },
            "line2": {
              "type": "string",
              "description": "Apt, Suite, Unit, etc."
            },
            "city": {
              "type": "string"
            },
            "state": {
              "type": "string",
              "description": "2-letter state code."
            },
            "postal_code": {
              "type": "string"
            }
          }
        },
        "phone": {
          "type": "object",
          "description": "Phone/fax as shown on document.",
          "properties": {
            "raw_text": {
              "type": "string"
            },
            "digits": {
              "type": "string",
              "description": "10-digit US number, digits only."
            },
            "extension": {
              "type": "string"
            }
          }
        },
        "fax": {
          "type": "object",
          "description": "Phone/fax as shown on document.",
          "properties": {
            "raw_text": {
              "type": "string"
            },
            "digits": {
              "type": "string",
              "description": "10-digit US number, digits only."
            },
            "extension": {
              "type": "string"
            }
          }
        },
        "clia_number": {
          "type": "string",
          "description": "CLIA only if printed."
        },
        "lab_director": {
          "type": "string",
          "description": "Laboratory director name, if printed."
        }
      }
    },
    "providers": {
      "type": "array",
      "description": "All providers named on the document with their role.",
      "items": {
        "type": "object",
        "description": "Provider as identified on the fax. Only from text on the page.",
        "properties": {
          "role": {
            "type": "string",
            "description": "Role as printed or implied by section: 'Ordering', 'Attending', 'Radiologist', 'Signed by', etc."
          },
          "name": {
            "type": "object",
            "properties": {
              "raw_text": {
                "type": "string"
              },
              "prefix": {
                "type": "string",
                "description": "Dr., etc."
              },
              "first_name": {
                "type": "string"
              },
              "middle_name": {
                "type": "string"
              },
              "last_name": {
                "type": "string"
              },
              "suffix": {
                "type": "string"
              }
            }
          },
          "credentials": {
            "type": "array",
            "description": "Credentials as printed: ['MD'], ['DO','FACP'], ['NP'].",
            "items": {
              "type": "string"
            }
          },
          "npi": {
            "type": "string",
            "description": "NPI only if printed on the fax."
          },
          "specialty": {
            "type": "string"
          },
          "phone": {
            "type": "object",
            "description": "Phone/fax as shown on document.",
            "properties": {
              "raw_text": {
                "type": "string"
              },
              "digits": {
                "type": "string",
                "description": "10-digit US number, digits only."
              },
              "extension": {
                "type": "string"
              }
            }
          },
          "fax": {
            "type": "object",
            "description": "Phone/fax as shown on document.",
            "properties": {
              "raw_text": {
                "type": "string"
              },
              "digits": {
                "type": "string",
                "description": "10-digit US number, digits only."
              },
              "extension": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "classifier_top_candidates": {
      "type": "array",
      "description": "Candidate categories the classifier considered with confidence scores \u2014 helps human reviewer route.",
      "items": {
        "type": "object",
        "properties": {
          "category": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "rationale": {
            "type": "string"
          }
        }
      }
    },
    "document_appears_to_be": {
      "type": "string",
      "description": "Free-text extractor guess."
    },
    "key_content_excerpts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reason_for_unclassified": {
      "type": "string",
      "description": "As evident: 'low OCR quality', 'no clear category match', 'ambiguous between categories', 'partial document', 'corrupted/blank pages', 'handwritten only', 'not English'."
    },
    "full_text": {
      "type": "string",
      "description": "Full OCR text of the document for auditing, search, and reprocessing."
    },
    "fax_envelope": {
      "type": "object",
      "description": "Transmission metadata from fax service \u2014 not content from the document.",
      "properties": {
        "received_at": {
          "type": "string",
          "format": "date-time"
        },
        "from_fax_number": {
          "type": "string"
        },
        "to_fax_number": {
          "type": "string"
        },
        "csid_banner": {
          "type": "string"
        },
        "page_count": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "extraction_meta": {
      "type": "object",
      "properties": {
        "extractor_version": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "schema_id": {
          "type": "string"
        },
        "extracted_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  },
  "required": [
    "document_category"
  ],
  "examples": [
    {
      "document_category": "unclassified",
      "document_subcategory": "ambiguous",
      "patient": {
        "name": {
          "raw_text": "partial text, illegible"
        },
        "identifiers": []
      },
      "sender": {
        "name": "Unknown"
      },
      "providers": [],
      "classifier_top_candidates": [
        {
          "category": "consult_note",
          "confidence": 0.38,
          "rationale": "Letter format with provider signature and diagnoses"
        },
        {
          "category": "medical_records_request",
          "confidence": 0.22,
          "rationale": "References HIPAA and asks for records"
        },
        {
          "category": "referral_incoming",
          "confidence": 0.19,
          "rationale": "Mentions referring to specialist"
        }
      ],
      "document_appears_to_be": "Letter from out-of-state provider that reads partly as a consult summary and partly as a records request \u2014 ambiguous intent.",
      "key_content_excerpts": [
        "...referring to your office for follow-up...",
        "...please forward any prior records to...",
        "...signed Dr. Evans, Ohio Medical Group..."
      ],
      "reason_for_unclassified": "Ambiguous between categories",
      "fax_envelope": {
        "received_at": "2026-04-22T17:18:22",
        "page_count": 2
      },
      "extraction_meta": {
        "extractor_version": "0.1.0",
        "schema_id": "https://cevi.ai/schemas/unclassified.schema.json",
        "extracted_at": "2026-04-22T17:19:14"
      }
    }
  ]
}