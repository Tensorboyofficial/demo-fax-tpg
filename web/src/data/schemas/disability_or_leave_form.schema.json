  "properties": {
    "document_category": {
      "type": "string",
      "const": "disability_or_leave_form"
    },
    "document_subcategory": {
      "type": "string",
      "enum": [
        "fmla_wh380e_serious_own_condition",
        "fmla_wh380f_family_member",
        "fmla_wh384_military_family",
        "fmla_wh385_covered_servicemember",
        "std_private_insurer",
        "ltd_private_insurer",
        "ssa_3368_adult_disability_report",
        "ssa_3369_work_history",
        "ssa_827_authorization",
        "ssa_medical_source_statement",
        "aflac_claim_form",
        "workers_comp_tx_dwc73_work_status",
        "workers_comp_tx_dwc69_mmi_impairment",
        "workers_comp_generic",
        "va_21_0960_dbq",
        "state_medicaid_disability",
        "leave_of_absence_generic",
        "fit_for_duty_certification",
        "return_to_work_release",
        "ada_reasonable_accommodation",
        "jury_duty_medical_excuse",
        "other"
      ]
    },
