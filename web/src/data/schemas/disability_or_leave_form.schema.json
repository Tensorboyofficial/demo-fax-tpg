{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cevi.ai/schemas/disability_or_leave_form.schema.json",
  "title": "Cevi AI \u2014 Disability or Leave Form",
  "description": "Provider-signed forms certifying medical condition for leave, disability, or accommodation: FMLA (WH-380-E/F/384/385), STD/LTD from private insurers (Hartford, Unum, Lincoln, MetLife), SSA disability forms (3368, 3369, 827), Aflac, Texas workers comp (DWC-73, DWC-69), VA DBQs (21-0960), ADA accommodation, fit-for-duty, return-to-work.",
