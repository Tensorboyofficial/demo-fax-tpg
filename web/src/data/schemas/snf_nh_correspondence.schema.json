        "page_count": 2
      },
      "extraction_meta": {
        "extractor_version": "0.1.0",
        "schema_id": "https://cevi.ai/schemas/snf_nh_correspondence.schema.json",
        "extracted_at": "2026-04-22T10:13:22"
      }
    }
  ]
}