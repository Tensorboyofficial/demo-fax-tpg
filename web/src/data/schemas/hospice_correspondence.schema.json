{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cevi.ai/schemas/hospice_correspondence.schema.json",
  "title": "Cevi AI \u2014 Hospice Correspondence",
  "description": "Hospice election notices, certification of terminal illness (initial + recert), face-to-face attestations, level-of-care changes, medication orders, death notifications, discharge/revocation. Captures terminal diagnosis, prognosis statement, level of care, and any requested action from the hospice.",
  "type": "object",
  "properties": {
    "document_category": {
      "type": "string",
      "const": "hospice_correspondence"
    },
    "document_subcategory": {
      "type": "string",
      "enum": [
        "election_notice",
        "cti_initial",
        "cti_recert",
        "face_to_face",
        "level_of_care_change",
        "medication_order",
        "death_notification",
        "general_inpatient_notice",
        "respite_care_notice",
        "discharge_revocation",
        "attending_physician_change",
        "other"
      ]
    },
    "patient": {
      "type": "object",
      "description": "Patient as identified on the fax. Does NOT include eCW account number or matcher output \u2014 matching runs after extraction.",
      "properties": {
        "name": {
          "type": "object",
          "description": "Person name with verbatim raw_text plus parsed components for separate copy-paste.",
          "properties": {
            "raw_text": {
              "type": "string",
              "description": "Verbatim name string as printed."
            },
            "first_name": {
              "type": "string"
            },
            "middle_name": {
              "type": "string"
            },
            "last_name": {
              "type": "string"
            },
            "suffix": {
              "type": "string"
            }
          }
        },
        "dob": {
          "type": "string",
          "format": "date",
          "description": "ISO date YYYY-MM-DD when parseable. Omit if ambiguous."
        },
        "dob_raw": {
          "type": "string",
          "description": "Verbatim DOB string as printed."
        },
        "sex": {
          "type": "string",
          "description": "Sex as printed. Typical values: M, F, Male, Female, Unknown."
        },
        "address": {
          "type": "object",
          "description": "Postal address from document. Each component is its own field.",
          "properties": {
            "raw_text": {
              "type": "string",
              "description": "Verbatim multi-line address as printed."
            },
            "line1": {
              "type": "string"
            },
            "line2": {
              "type": "string",
              "description": "Apt, Suite, Unit, etc."
            },
            "city": {
              "type": "string"
            },
            "state": {
              "type": "string",
              "description": "2-letter state code."
            },
            "postal_code": {
              "type": "string"
            }
          }
        },
        "phone": {
          "type": "object",
          "description": "Phone/fax as shown on document.",
          "properties": {
            "raw_text": {
              "type": "string"
            },
            "digits": {
              "type": "string",
              "description": "10-digit US number, digits only."
            },
            "extension": {
              "type": "string"
            }
          }
        },
        "identifiers": {
          "type": "array",
          "description": "Patient identifiers printed on the fax. Captured as printed with the label used.",
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string",
                "description": "Label as printed: 'Lab MRN', 'Account #', 'Member ID', etc."
              },
              "value": {
                "type": "string"
              }
            },
            "required": [
              "label",
              "value"
            ]
          }
        }
      }
    },
    "sender": {
      "type": "object",
      "description": "Organization that sent the fax (lab, hospital, pharmacy, law firm, payer, etc.).",
      "properties": {
        "name": {
          "type": "string"
        },
        "address": {
          "type": "object",
          "description": "Postal address from document. Each component is its own field.",
          "properties": {
            "raw_text": {
              "type": "string",
              "description": "Verbatim multi-line address as printed."
            },
            "line1": {
              "type": "string"
            },
            "line2": {
              "type": "string",
              "description": "Apt, Suite, Unit, etc."
            },
            "city": {
              "type": "string"
            },
            "state": {
              "type": "string",
              "description": "2-letter state code."
            },
            "postal_code": {
              "type": "string"
            }
          }
        },
        "phone": {
          "type": "object",
          "description": "Phone/fax as shown on document.",
          "properties": {
            "raw_text": {
              "type": "string"
            },
            "digits": {
              "type": "string",
              "description": "10-digit US number, digits only."
            },
            "extension": {
              "type": "string"
            }
          }
        },
        "fax": {
          "type": "object",
          "description": "Phone/fax as shown on document.",
          "properties": {
            "raw_text": {
              "type": "string"
            },
            "digits": {
              "type": "string",
              "description": "10-digit US number, digits only."
            },
            "extension": {
              "type": "string"
            }
          }
        },
        "clia_number": {
          "type": "string",
          "description": "CLIA only if printed."
        },
        "lab_director": {
          "type": "string",
          "description": "Laboratory director name, if printed."
        }
      }
    },
    "providers": {
      "type": "array",
      "description": "All providers named on the document with their role.",
      "items": {
        "type": "object",
        "description": "Provider as identified on the fax. Only from text on the page.",
        "properties": {
          "role": {
            "type": "string",
            "description": "Role as printed or implied by section: 'Ordering', 'Attending', 'Radiologist', 'Signed by', etc."
          },
          "name": {
            "type": "object",
            "properties": {
              "raw_text": {
                "type": "string"
              },
              "prefix": {
                "type": "string",
                "description": "Dr., etc."
              },
              "first_name": {
                "type": "string"
              },
              "middle_name": {
                "type": "string"
              },
              "last_name": {
                "type": "string"
              },
              "suffix": {
                "type": "string"
              }
            }
          },
          "credentials": {
            "type": "array",
            "description": "Credentials as printed: ['MD'], ['DO','FACP'], ['NP'].",
            "items": {
              "type": "string"
            }
          },
          "npi": {
            "type": "string",
            "description": "NPI only if printed on the fax."
          },
          "specialty": {
            "type": "string"
          },
          "phone": {
            "type": "object",
            "description": "Phone/fax as shown on document.",
            "properties": {
              "raw_text": {
                "type": "string"
              },
              "digits": {
                "type": "string",
                "description": "10-digit US number, digits only."
              },
              "extension": {
                "type": "string"
              }
            }
          },
          "fax": {
            "type": "object",
            "description": "Phone/fax as shown on document.",
            "properties": {
              "raw_text": {
                "type": "string"
              },
              "digits": {
                "type": "string",
                "description": "10-digit US number, digits only."
              },
              "extension": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "document_type": {
      "type": "string",
      "description": "Type as printed: 'Hospice Election', 'Certification of Terminal Illness', 'Face-to-Face Encounter', 'Level of Care Change', 'Death Notification', 'Medication Order'."
    },
    "election_date": {
      "type": "string",
      "format": "date"
    },
    "election_date_raw": {
      "type": "string"
    },
    "benefit_period_number": {
      "type": "string"
    },
    "certification_period_start": {
      "type": "string",
      "format": "date"
    },
    "certification_period_end": {
      "type": "string",
      "format": "date"
    },
    "face_to_face_date": {
      "type": "string",
      "format": "date"
    },
    "death_datetime": {
      "type": "string",
      "format": "date-time"
    },
    "death_datetime_raw": {
      "type": "string"
    },
    "terminal_diagnosis": {
      "type": "object",
      "description": "Diagnosis as printed.",
      "properties": {
        "description": {
          "type": "string",
          "description": "Diagnosis text as printed."
        },
        "icd10": {
          "type": "string",
          "description": "ICD-10 code only if printed on the fax."
        }
      }
    },
    "related_conditions": {
      "type": "array",
      "items": {
        "type": "object",
        "description": "Diagnosis as printed.",
        "properties": {
          "description": {
            "type": "string",
            "description": "Diagnosis text as printed."
          },
          "icd10": {
            "type": "string",
            "description": "ICD-10 code only if printed on the fax."
          }
        }
      }
    },
    "prognosis_statement": {
      "type": "string",
      "description": "6-month-or-less prognosis statement verbatim, required for Medicare hospice."
    },
    "clinical_findings_supporting_prognosis": {
      "type": "string"
    },
    "level_of_care": {
      "type": "string",
      "description": "As printed: 'Routine home care', 'Continuous home care', 'Inpatient respite', 'General inpatient'."
    },
    "patient_location": {
      "type": "string",
      "description": "As printed: 'Home', 'Assisted living', 'Nursing facility', 'Inpatient hospice'."
    },
    "medication_orders": {
      "type": "array",
      "items": {
        "type": "object",
        "description": "Medication as listed on the document.",
        "properties": {
          "name": {
            "type": "string",
            "description": "Medication name as printed (generic or brand)."
          },
          "strength": {
            "type": "string",
            "description": "E.g., '500 mg', '10 mg/mL'."
          },
          "dose": {
            "type": "string",
            "description": "E.g., '1 tablet', '2 puffs'."
          },
          "route": {
            "type": "string",
            "description": "E.g., 'PO', 'IV', 'SC', 'inhaled'."
          },
          "frequency": {
            "type": "string",
            "description": "E.g., 'once daily', 'BID with meals', 'q6h PRN pain'."
          },
          "sig": {
            "type": "string",
            "description": "Full sig string if printed as a single line."
          },
          "indication": {
            "type": "string"
          },
          "raw_text": {
            "type": "string",
            "description": "Verbatim line as printed, if it doesn't split cleanly."
          }
        }
      }
    },
    "code_status": {
      "type": "string"
    },
    "attestation_text": {
      "type": "string",
      "description": "Provider attestation text verbatim."
    },
    "requested_action": {
      "type": "string"
    },
    "physician_signature_present": {
      "type": "string"
    },
    "physician_signature_date": {
      "type": "string",
      "format": "date"
    },
    "full_text": {
      "type": "string",
      "description": "Full OCR text of the document for auditing, search, and reprocessing."
    },
    "fax_envelope": {
      "type": "object",
      "description": "Transmission metadata from fax service \u2014 not content from the document.",
      "properties": {
        "received_at": {
          "type": "string",
          "format": "date-time"
        },
        "from_fax_number": {
          "type": "string"
        },
        "to_fax_number": {
          "type": "string"
        },
        "csid_banner": {
          "type": "string"
        },
        "page_count": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "extraction_meta": {
      "type": "object",
      "properties": {
        "extractor_version": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "schema_id": {
          "type": "string"
        },
        "extracted_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  },
  "required": [
    "document_category",
    "patient"
  ],
  "examples": [
    {
      "document_category": "hospice_correspondence",
      "document_subcategory": "death_notification",
      "patient": {
        "name": {
          "raw_text": "MILLER, DOROTHY JANE",
          "first_name": "Dorothy",
          "middle_name": "Jane",
          "last_name": "Miller"
        },
        "dob": "1934-02-28",
        "dob_raw": "02/28/1934",
        "sex": "F",
        "identifiers": [
          {
            "label": "Medicare",
            "value": "3CD4EF5GH67"
          }
        ]
      },
      "sender": {
        "name": "VITAS Healthcare - Dallas",
        "address": {
          "raw_text": "17300 Preston Rd, Suite 200, Dallas, TX 75252",
          "line1": "17300 Preston Rd",
          "line2": "Suite 200",
          "city": "Dallas",
          "state": "TX",
          "postal_code": "75252"
        },
        "phone": {
          "raw_text": "214-555-9900",
          "digits": "2145559900"
        }
      },
      "providers": [
        {
          "role": "Medical Director",
          "name": {
            "raw_text": "Sarah Abernathy, MD",
            "first_name": "Sarah",
            "last_name": "Abernathy"
          },
          "credentials": [
            "MD"
          ],
          "specialty": "Hospice and Palliative Medicine"
        },
        {
          "role": "PCP",
          "name": {
            "raw_text": "Priya Patel, DO",
            "first_name": "Priya",
            "last_name": "Patel"
          },
          "credentials": [
            "DO"
          ]
        }
      ],
      "document_type": "Death Notification",
      "election_date": "2026-02-14",
      "death_datetime": "2026-04-21T14:32:00",
      "death_datetime_raw": "04/21/2026 2:32 PM",
      "terminal_diagnosis": {
