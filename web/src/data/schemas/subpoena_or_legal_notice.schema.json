{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cevi.ai/schemas/subpoena_or_legal_notice.schema.json",
  "title": "Cevi AI \u2014 Subpoena or Legal Notice",
  "description": "Court-ordered or attorney-issued compulsory demands: subpoena duces tecum (records), subpoena ad testificandum (deposition), trial subpoenas, court orders, preservation-of-evidence (litigation hold) letters, notices of lawsuit. HIPAA qualifying protective order / satisfactory assurances status captured as printed.",
  "type": "object",
  "properties": {
    "document_category": {
      "type": "string",
      "const": "subpoena_or_legal_notice"
    },
    "document_subcategory": {
      "type": "string",
      "enum": [
        "subpoena_duces_tecum_records",
        "subpoena_ad_testificandum_deposition",
        "subpoena_trial_testimony",
        "court_order",
        "administrative_order",
        "search_warrant",
        "preservation_of_evidence_letter",
        "spoliation_letter",
        "notice_of_lawsuit",
        "expert_retention_request",
        "other"
      ]
    },
    "patient": {
      "type": "object",
      "description": "Patient as identified on the fax. Does NOT include eCW account number or matcher output \u2014 matching runs after extraction.",
      "properties": {
        "name": {
          "type": "object",
          "description": "Person name with verbatim raw_text plus parsed components for separate copy-paste.",
          "properties": {
            "raw_text": {
              "type": "string",
              "description": "Verbatim name string as printed."
            },
            "first_name": {
              "type": "string"
            },
            "middle_name": {
              "type": "string"
            },
            "last_name": {
              "type": "string"
            },
            "suffix": {
              "type": "string"
            }
          }
        },
        "dob": {
          "type": "string",
          "format": "date",
          "description": "ISO date YYYY-MM-DD when parseable. Omit if ambiguous."
        },
        "dob_raw": {
          "type": "string",
          "description": "Verbatim DOB string as printed."
        },
        "sex": {
          "type": "string",
          "description": "Sex as printed. Typical values: M, F, Male, Female, Unknown."
        },
        "address": {
          "type": "object",
          "description": "Postal address from document. Each component is its own field.",
          "properties": {
            "raw_text": {
              "type": "string",
              "description": "Verbatim multi-line address as printed."
            },
            "line1": {
              "type": "string"
            },
            "line2": {
              "type": "string",
              "description": "Apt, Suite, Unit, etc."
            },
            "city": {
              "type": "string"
            },
            "state": {
              "type": "string",
              "description": "2-letter state code."
            },
            "postal_code": {
              "type": "string"
            }
          }
        },
        "phone": {
          "type": "object",
          "description": "Phone/fax as shown on document.",
          "properties": {
            "raw_text": {
              "type": "string"
            },
            "digits": {
              "type": "string",
              "description": "10-digit US number, digits only."
            },
            "extension": {
              "type": "string"
            }
          }
        },
        "identifiers": {
          "type": "array",
          "description": "Patient identifiers printed on the fax. Captured as printed with the label used.",
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string",
                "description": "Label as printed: 'Lab MRN', 'Account #', 'Member ID', etc."
              },
              "value": {
                "type": "string"
              }
            },
            "required": [
              "label",
              "value"
            ]
          }
        }
      }
    },
    "sender": {
      "type": "object",
      "description": "Organization that sent the fax (lab, hospital, pharmacy, law firm, payer, etc.).",
      "properties": {
        "name": {
          "type": "string"
        },
        "address": {
          "type": "object",
          "description": "Postal address from document. Each component is its own field.",
          "properties": {
            "raw_text": {
              "type": "string",
              "description": "Verbatim multi-line address as printed."
            },
            "line1": {
              "type": "string"
            },
            "line2": {
              "type": "string",
              "description": "Apt, Suite, Unit, etc."
            },
            "city": {
              "type": "string"
            },
            "state": {
              "type": "string",
              "description": "2-letter state code."
            },
            "postal_code": {
              "type": "string"
            }
          }
        },
        "phone": {
          "type": "object",
          "description": "Phone/fax as shown on document.",
          "properties": {
            "raw_text": {
              "type": "string"
            },
            "digits": {
              "type": "string",
              "description": "10-digit US number, digits only."
            },
            "extension": {
              "type": "string"
            }
          }
        },
        "fax": {
          "type": "object",
          "description": "Phone/fax as shown on document.",
          "properties": {
            "raw_text": {
              "type": "string"
            },
            "digits": {
              "type": "string",
              "description": "10-digit US number, digits only."
            },
            "extension": {
              "type": "string"
            }
          }
        },
        "clia_number": {
          "type": "string",
          "description": "CLIA only if printed."
        },
        "lab_director": {
          "type": "string",
          "description": "Laboratory director name, if printed."
        }
      }
    },
    "providers": {
      "type": "array",
      "description": "All providers named on the document with their role.",
      "items": {
        "type": "object",
        "description": "Provider as identified on the fax. Only from text on the page.",
        "properties": {
          "role": {
            "type": "string",
            "description": "Role as printed or implied by section: 'Ordering', 'Attending', 'Radiologist', 'Signed by', etc."
          },
          "name": {
            "type": "object",
            "properties": {
              "raw_text": {
                "type": "string"
              },
              "prefix": {
                "type": "string",
                "description": "Dr., etc."
              },
              "first_name": {
                "type": "string"
              },
              "middle_name": {
                "type": "string"
              },
              "last_name": {
                "type": "string"
              },
              "suffix": {
                "type": "string"
              }
            }
          },
          "credentials": {
            "type": "array",
            "description": "Credentials as printed: ['MD'], ['DO','FACP'], ['NP'].",
            "items": {
              "type": "string"
            }
          },
          "npi": {
            "type": "string",
            "description": "NPI only if printed on the fax."
          },
          "specialty": {
            "type": "string"
          },
          "phone": {
            "type": "object",
            "description": "Phone/fax as shown on document.",
            "properties": {
              "raw_text": {
                "type": "string"
              },
              "digits": {
                "type": "string",
                "description": "10-digit US number, digits only."
              },
              "extension": {
                "type": "string"
              }
            }
          },
          "fax": {
            "type": "object",
            "description": "Phone/fax as shown on document.",
            "properties": {
              "raw_text": {
                "type": "string"
              },
              "digits": {
                "type": "string",
                "description": "10-digit US number, digits only."
              },
              "extension": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "notice_type": {
      "type": "string",
      "description": "As printed: 'Subpoena Duces Tecum', 'Subpoena Ad Testificandum', 'Trial Subpoena', 'Court Order', 'Preservation of Evidence Letter', 'Notice of Lawsuit'."
    },
    "issuing_court": {
      "type": "string",
      "description": "Court name as printed."
    },
    "court_jurisdiction": {
      "type": "string",
      "description": "As printed: 'Federal', 'State', 'County', 'Municipal'."
    },
    "case_caption": {
      "type": "string"
    },
    "case_number": {
      "type": "string"
    },
    "plaintiff": {
      "type": "string"
    },
    "defendant": {
      "type": "string"
    },
    "issuing_attorney": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "firm_name": {
          "type": "string"
        },
        "bar_number": {
          "type": "string"
        },
        "represents_party": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "fax": {
          "type": "string"
        }
      }
    },
    "date_served": {
      "type": "string",
      "format": "date",
      "description": "Date subpoena/notice was served on the practice."
    },
    "date_served_raw": {
      "type": "string"
    },
    "compliance_date": {
      "type": "string",
      "format": "date"
    },
    "compliance_date_raw": {
      "type": "string"
    },
    "appearance_datetime": {
      "type": "string",
      "format": "date-time"
    },
    "appearance_location": {
      "type": "string"
    },
    "records_to_produce": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "deposition_topics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "witness_fee_enclosed": {
      "type": "string"
    },
    "hipaa_protective_order_attached": {
      "type": "string",
      "description": "As seen: 'Yes', 'No'."
    },
    "hipaa_satisfactory_assurances_attached": {
      "type": "string"
    },
    "patient_authorization_attached": {
      "type": "string"
    },
    "preservation_hold_required": {
      "type": "string"
    },
    "consequences_of_non_compliance": {
      "type": "string"
    },
    "full_text": {
      "type": "string",
      "description": "Full OCR text of the document for auditing, search, and reprocessing."
    },
    "fax_envelope": {
      "type": "object",
      "description": "Transmission metadata from fax service \u2014 not content from the document.",
      "properties": {
        "received_at": {
          "type": "string",
          "format": "date-time"
        },
        "from_fax_number": {
          "type": "string"
        },
        "to_fax_number": {
          "type": "string"
        },
        "csid_banner": {
          "type": "string"
        },
        "page_count": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "extraction_meta": {
      "type": "object",
      "properties": {
        "extractor_version": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "schema_id": {
          "type": "string"
        },
        "extracted_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  },
  "required": [
    "document_category",
    "patient"
  ],
  "examples": [
    {
      "document_category": "subpoena_or_legal_notice",
      "document_subcategory": "subpoena_duces_tecum_records",
      "patient": {
        "name": {
          "raw_text": "Washington, DeShawn J.",
          "first_name": "DeShawn",
          "middle_name": "J.",
          "last_name": "Washington"
        },
        "dob": "1971-09-03",
