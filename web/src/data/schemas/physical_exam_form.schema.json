        "grade_level": {
          "type": "string"
        },
        "school_name": {
          "type": "string"
        },
        "cdl_class": {
          "type": "string"
        },
        "license_number": {
          "type": "string"
        }
      }
    },
    "health_history_responses": {
      "type": "array",
      "description": "Yes/no/explanation responses to the form's health history questions. Each form has different questions.",
      "items": {
        "type": "object",
        "properties": {
          "question": {
            "type": "string"
          },
          "response": {
            "type": "string",
            "description": "As marked: 'Yes', 'No', 'Unknown', 'Declined', empty."
          },
          "explanation": {
            "type": "string"
          }
        }
      }
    },
    "vital_signs": {
      "type": "object",
      "properties": {
        "bp": {
          "type": "string"
        },
        "pulse": {
          "type": "string"
        },
        "respiratory_rate": {
          "type": "string"
        },
        "temperature": {
          "type": "string"
        },
        "height": {
          "type": "string"
        },
        "weight": {
          "type": "string"
        },
        "bmi": {
          "type": "string"
        },
        "vision_right_corrected": {
