      "description": "As printed: 'Meets standards - 2 year', 'Meets standards - 1 year', 'Does not meet standards', 'Cleared for all sports', 'Cleared with restrictions', 'Not cleared', 'Pending further evaluation'."
    },
    "certification_decision_notes": {
      "type": "string"
    },
    "restrictions_or_monitoring": {
      "type": "string"
    },
    "medications_disclosed": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "dose": {
            "type": "string"
          },
          "indication": {
            "type": "string"
          }
        }
      }
    },
    "provider_signature_present": {
      "type": "string"
    },
    "provider_signature_date": {
      "type": "string",
      "format": "date"
    },
    "provider_national_registry_number": {
      "type": "string",
      "description": "For DOT exams: FMCSA National Registry number if printed."
    },
    "provider_license_number": {
      "type": "string"
    },
    "full_text": {
      "type": "string",
      "description": "Full OCR text of the document for auditing, search, and reprocessing."
    },
    "fax_envelope": {
      "type": "object",
      "description": "Transmission metadata from fax service \u2014 not content from the document.",
      "properties": {
        "received_at": {
          "type": "string",
          "format": "date-time"
        },
        "from_fax_number": {
          "type": "string"
        },
        "to_fax_number": {
          "type": "string"
        },
        "csid_banner": {
          "type": "string"
        },
        "page_count": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "extraction_meta": {
      "type": "object",
      "properties": {
        "extractor_version": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "schema_id": {
          "type": "string"
        },
        "extracted_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  },
  "required": [
    "document_category",
    "patient"
  ],
