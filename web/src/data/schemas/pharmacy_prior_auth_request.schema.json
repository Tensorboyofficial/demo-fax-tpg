        }
      ],
      "response_deadline": "2026-04-29",
      "response_fax_number": "866-443-1172",
      "member_details": {
        "member_id": "XBR483920174",
        "group_number": "482910",
        "plan_name": "BCBS TX PPO"
      },
      "fax_envelope": {
        "received_at": "2026-04-22T14:18:42",
        "page_count": 4,
        "csid_banner": "COVERMYMEDS"
      },
      "extraction_meta": {
        "extractor_version": "0.1.0",
        "schema_id": "https://cevi.ai/schemas/pharmacy_prior_auth_request.schema.json",
        "extracted_at": "2026-04-22T14:19:28"
      }
    }
  ]
}