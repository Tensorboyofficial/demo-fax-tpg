        },
        {
          "question": "Is the patient being prescribed this medication for weight loss only (non-diabetic indication)?"
        }
      ],
      "failed_or_tried_medications": [
        {
          "medication": "Metformin 1000 mg BID",
          "dates_tried": "2014-present",
          "reason_discontinued": "Continued; partial control, A1c still elevated."
        },
        {
