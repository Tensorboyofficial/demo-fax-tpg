{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://cevi.ai/schemas/dme_documentation.schema.json",
  "title": "Cevi AI \u2014 DME Documentation",
  "description": "DME paperwork: Standard Written Orders (SWO), Written Orders Prior to Delivery (WOPD), legacy Certificates of Medical Necessity (CMN), face-to-face evaluations, supply refill requests, proof of delivery. Equipment items captured with HCPCS codes if printed. CPAP-specific sleep study and oxygen-specific qualifying test blocks populated when relevant.",
  "type": "object",
  "properties": {
    "document_category": {
      "type": "string",
      "const": "dme_documentation"
    },
    "document_subcategory": {
      "type": "string",
      "enum": [
        "cpap_initial_order",
        "cpap_supply_refill",
        "bipap",
        "oxygen",
        "nebulizer",
        "diabetic_supplies",
        "walker_cane",
        "wheelchair_standard",
        "wheelchair_complex",
        "hospital_bed",
        "ostomy_supplies",
        "urological_supplies",
        "wound_care_supplies",
        "compression_garment",
        "breast_pump",
        "other"
      ]
    },
    "patient": {
      "type": "object",
      "description": "Patient as identified on the fax. Does NOT include eCW account number or matcher output \u2014 matching runs after extraction.",
      "properties": {
        "name": {
          "type": "object",
          "description": "Person name with verbatim raw_text plus parsed components for separate copy-paste.",
          "properties": {
            "raw_text": {
              "type": "string",
              "description": "Verbatim name string as printed."
            },
            "first_name": {
              "type": "string"
            },
            "middle_name": {
              "type": "string"
            },
            "last_name": {
              "type": "string"
            },
            "suffix": {
              "type": "string"
            }
          }
        },
        "dob": {
          "type": "string",
          "format": "date",
          "description": "ISO date YYYY-MM-DD when parseable. Omit if ambiguous."
        },
        "dob_raw": {
          "type": "string",
          "description": "Verbatim DOB string as printed."
        },
        "sex": {
          "type": "string",
          "description": "Sex as printed. Typical values: M, F, Male, Female, Unknown."
        },
        "address": {
          "type": "object",
          "description": "Postal address from document. Each component is its own field.",
          "properties": {
            "raw_text": {
              "type": "string",
              "description": "Verbatim multi-line address as printed."
            },
            "line1": {
              "type": "string"
            },
            "line2": {
              "type": "string",
              "description": "Apt, Suite, Unit, etc."
            },
            "city": {
              "type": "string"
            },
            "state": {
              "type": "string",
              "description": "2-letter state code."
            },
            "postal_code": {
              "type": "string"
            }
          }
        },
        "phone": {
          "type": "object",
          "description": "Phone/fax as shown on document.",
          "properties": {
            "raw_text": {
              "type": "string"
            },
            "digits": {
              "type": "string",
              "description": "10-digit US number, digits only."
            },
            "extension": {
              "type": "string"
            }
          }
        },
        "identifiers": {
          "type": "array",
          "description": "Patient identifiers printed on the fax. Captured as printed with the label used.",
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string",
                "description": "Label as printed: 'Lab MRN', 'Account #', 'Member ID', etc."
              },
              "value": {
                "type": "string"
              }
            },
            "required": [
              "label",
              "value"
            ]
          }
        }
      }
    },
    "sender": {
      "type": "object",
      "description": "Organization that sent the fax (lab, hospital, pharmacy, law firm, payer, etc.).",
      "properties": {
        "name": {
          "type": "string"
        },
        "address": {
          "type": "object",
          "description": "Postal address from document. Each component is its own field.",
          "properties": {
            "raw_text": {
              "type": "string",
              "description": "Verbatim multi-line address as printed."
            },
            "line1": {
              "type": "string"
            },
            "line2": {
              "type": "string",
              "description": "Apt, Suite, Unit, etc."
            },
            "city": {
              "type": "string"
            },
            "state": {
              "type": "string",
              "description": "2-letter state code."
            },
            "postal_code": {
              "type": "string"
            }
          }
        },
        "phone": {
          "type": "object",
          "description": "Phone/fax as shown on document.",
          "properties": {
            "raw_text": {
              "type": "string"
            },
            "digits": {
              "type": "string",
              "description": "10-digit US number, digits only."
            },
            "extension": {
              "type": "string"
            }
          }
        },
        "fax": {
          "type": "object",
          "description": "Phone/fax as shown on document.",
          "properties": {
            "raw_text": {
              "type": "string"
            },
            "digits": {
              "type": "string",
              "description": "10-digit US number, digits only."
            },
            "extension": {
              "type": "string"
            }
          }
        },
        "clia_number": {
          "type": "string",
          "description": "CLIA only if printed."
        },
        "lab_director": {
          "type": "string",
          "description": "Laboratory director name, if printed."
        }
      }
    },
    "providers": {
      "type": "array",
      "description": "All providers named on the document with their role.",
      "items": {
        "type": "object",
        "description": "Provider as identified on the fax. Only from text on the page.",
        "properties": {
          "role": {
            "type": "string",
            "description": "Role as printed or implied by section: 'Ordering', 'Attending', 'Radiologist', 'Signed by', etc."
          },
          "name": {
            "type": "object",
            "properties": {
              "raw_text": {
                "type": "string"
              },
              "prefix": {
                "type": "string",
                "description": "Dr., etc."
              },
              "first_name": {
                "type": "string"
              },
              "middle_name": {
                "type": "string"
              },
              "last_name": {
                "type": "string"
              },
              "suffix": {
                "type": "string"
              }
            }
          },
          "credentials": {
            "type": "array",
            "description": "Credentials as printed: ['MD'], ['DO','FACP'], ['NP'].",
            "items": {
              "type": "string"
            }
          },
          "npi": {
            "type": "string",
            "description": "NPI only if printed on the fax."
          },
          "specialty": {
            "type": "string"
          },
          "phone": {
            "type": "object",
            "description": "Phone/fax as shown on document.",
            "properties": {
              "raw_text": {
                "type": "string"
              },
              "digits": {
                "type": "string",
                "description": "10-digit US number, digits only."
              },
              "extension": {
                "type": "string"
              }
            }
          },
          "fax": {
            "type": "object",
            "description": "Phone/fax as shown on document.",
            "properties": {
              "raw_text": {
                "type": "string"
              },
              "digits": {
                "type": "string",
                "description": "10-digit US number, digits only."
              },
              "extension": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "form_type": {
      "type": "string",
      "description": "Form type as printed: 'Standard Written Order', 'Written Order Prior to Delivery (WOPD)', 'Certificate of Medical Necessity', 'Face-to-Face Evaluation', 'Supply Refill Request', 'Proof of Delivery'."
    },
    "equipment_requested": {
      "type": "array",
      "description": "DME items as listed on the form.",
      "items": {
        "type": "object",
        "properties": {
          "description": {
            "type": "string"
          },
          "hcpcs_code": {
            "type": "string",
            "description": "HCPCS code only if printed, e.g. 'E0601', 'E0470', 'A4253'."
          },
          "quantity": {
            "type": "string"
          },
          "frequency": {
            "type": "string",
            "description": "For supplies: 'monthly', 'every 3 months'."
          },
          "rental_or_purchase": {
            "type": "string"
          },
          "length_of_need": {
            "type": "string",
            "description": "As printed: '99 months (lifetime)', '13 months', '3 months'."
          }
        }
      }
    },
    "diagnoses_supporting_necessity": {
      "type": "array",
      "items": {
        "type": "object",
        "description": "Diagnosis as printed.",
        "properties": {
          "description": {
            "type": "string",
            "description": "Diagnosis text as printed."
          },
          "icd10": {
            "type": "string",
            "description": "ICD-10 code only if printed on the fax."
          }
        }
      }
    },
    "medical_necessity_justification": {
      "type": "string"
    },
    "face_to_face_encounter": {
      "type": "object",
      "properties": {
        "encounter_date": {
          "type": "string",
          "format": "date"
        },
        "encounter_date_raw": {
          "type": "string"
        },
        "provider_name": {
          "type": "string"
        },
        "clinical_findings": {
          "type": "string"
        }
      }
    },
    "sleep_study_documentation": {
      "type": "object",
      "description": "For CPAP/BiPAP orders.",
      "properties": {
        "study_date": {
          "type": "string",
          "format": "date"
        },
        "study_type": {
          "type": "string"
        },
        "ahi": {
          "type": "string",
          "description": "AHI as printed."
        },
        "rdi": {
          "type": "string"
        }
      }
    },
    "oxygen_qualifying_test": {
      "type": "object",
      "description": "For oxygen orders. Values as printed.",
      "properties": {
        "liters_per_minute": {
          "type": "string"
        },
        "use_pattern": {
          "type": "string"
        },
        "resting_spo2": {
          "type": "string"
        },
        "resting_pao2": {
          "type": "string"
        },
        "qualifying_test_date": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "supplier_requested_action": {
      "type": "string",
      "description": "What the DME vendor is asking the provider to do."
    },
    "signature_present": {
      "type": "string"
    },
    "signature_date": {
      "type": "string",
      "format": "date"
    },
    "full_text": {
      "type": "string",
      "description": "Full OCR text of the document for auditing, search, and reprocessing."
    },
    "fax_envelope": {
      "type": "object",
      "description": "Transmission metadata from fax service \u2014 not content from the document.",
      "properties": {
        "received_at": {
          "type": "string",
          "format": "date-time"
        },
        "from_fax_number": {
          "type": "string"
        },
        "to_fax_number": {
          "type": "string"
        },
        "csid_banner": {
          "type": "string"
        },
        "page_count": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "extraction_meta": {
      "type": "object",
      "properties": {
        "extractor_version": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "schema_id": {
          "type": "string"
        },
        "extracted_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  },
  "required": [
    "document_category",
    "patient"
  ],
  "examples": [
    {
